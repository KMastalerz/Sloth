**/.angular/cache
.sass-cache/
**/connect.lock
**/coverage
**/libpeerconnection.log
testem.log
**/typings

# System files
.DS_Store
Thumbs.db

# .NET Core
bin/
obj/

# ASP.NET Scaffolding
.vscode/
.vscode-test/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Logs
*.log

# NuGet
*.nupkg
*.snupkg
.nuget/

# Environment Variables
.env
.env.*.local

# Visual Studio Code
.vscode/

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# NPM Packages
node_modules/
package-lock.json
yarn.lock

# ASP.NET temporary files
App_Data/

# IIS Express
/.vs/
*.config

# Rider
.idea/
*.sln.iml

# Mono auto generated files
mono_crash.*

# macOS
.DS_Store

# Azure Pipelines
.azure-pipelines/

# Additional files generated by Visual Studio
.vs/

# JetBrains Rider
.idea/

# Local History for Visual Studio
.localhistory/

# Coverage results
coverage/

# Exclude the generated wrapper code for COM interop
Interop/

# Backup & report files from converting an old project file
*.convertedproj
*.old
*.backup
*ReportConverter.xml

# Windows shortcut files
*.lnk
