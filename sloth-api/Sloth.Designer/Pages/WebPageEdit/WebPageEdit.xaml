<UserControl x:Class="Sloth.Designer.Pages.WebPageEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Sloth.Designer.Pages"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Sloth.Designer.Converters">
    <UserControl.Resources>
        <!-- Boolean to Visibility Converter (built-in in WPF but declare if needed) -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Empty Collection to Visibility Converter -->
        <converters:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal"
                    Grid.Column="0"
                    Margin="16 0 0 0">
            <Button Content="{materialDesign:PackIcon Kind=Add,Size=16}"
                    Height="24"
                    Width="24"
                    ToolTip="Add"
                    Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}"/>
            <Button Content="{materialDesign:PackIcon Kind=Delete,Size=16}"
                    Height="24"
                    Width="24"
                    ToolTip="Delete"
                    Margin="16 0"
                    Background="DarkGray"
                    BorderBrush="DarkGray"
                    Style="{StaticResource MaterialDesignFloatingActionMiniSecondaryButton}"/>
        </StackPanel>
        <StackPanel Grid.Column="1"
                    HorizontalAlignment="Right"
                    Margin="0 0 16 0">
            <Button ToolTip="Go back"
                    Command="{Binding GoBack}"
                    Style="{StaticResource MaterialDesignFlatDarkButton}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ArrowLeft"
                                             Margin="0 2 0 0"/>
                    <TextBlock Text="GO BACK" 
                               Margin="10 0 0 0"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="10 10 0 0">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ToggleButton   x:Name="ExpandPage"
                                    materialDesign:ToggleButtonAssist.OnContent="{materialDesign:PackIcon Kind=CollapseAll}"
                                    IsChecked="False"
                                    Content="{materialDesign:PackIcon Kind=ExpandAll}"
                                    Background="Transparent"
                                    Foreground="Black"
                                    Style="{StaticResource MaterialDesignActionToggleButton}"
                                    ToolTip="Show Panels"/>
                    <Button Content="{Binding WebPage.PageID}"
                            Style="{StaticResource MaterialDesignFlatDarkButton}"></Button>
                </StackPanel>
                <ItemsControl ItemsSource="{Binding WebPage.WebPanels}"
                              Visibility="{Binding IsChecked, ElementName=ExpandPage, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Margin="16 0 0 0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton   x:Name="ExpandPanel"
                                                    materialDesign:ToggleButtonAssist.OnContent="{materialDesign:PackIcon Kind=CollapseAll}"
                                                    IsChecked="False"
                                                    Content="{materialDesign:PackIcon Kind=ExpandAll}"
                                                    Background="Transparent"
                                                    Foreground="Black"
                                                    Style="{StaticResource MaterialDesignActionToggleButton}"
                                                    ToolTip="Show Sections and Controls"/>
                                    <Button Content="{Binding PanelID}"
                                            Style="{StaticResource MaterialDesignFlatButton}"></Button>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding WebSections}" 
                                              Margin="16 0 0 0"
                                              Visibility="{Binding IsChecked, ElementName=ExpandPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Vertical">
                                                <StackPanel Orientation="Horizontal">
                                                    <ToggleButton   x:Name="ExpandSection"
                                                                    materialDesign:ToggleButtonAssist.OnContent="{materialDesign:PackIcon Kind=CollapseAll}"
                                                                    IsChecked="False"
                                                                    Content="{materialDesign:PackIcon Kind=ExpandAll}"
                                                                    Background="Transparent"
                                                                    Foreground="Black"
                                                                    Style="{StaticResource MaterialDesignActionToggleButton}"
                                                                    ToolTip="Show Controls"/>
                                                    <Button Content="{Binding SectionID}"
                                                            Style="{StaticResource MaterialDesignFlatLightButton}"></Button>
                                                </StackPanel>
                                                <ItemsControl ItemsSource="{Binding WebControls}" 
                                                              Margin="48 0 0 0"
                                                              Visibility="{Binding IsChecked, ElementName=ExpandSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="{Binding ControlID}"
                                                                        Style="{StaticResource MaterialDesignFlatSecondaryDarkButton}"></Button>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding WebControls}" 
                                              Margin="48 0 0 0"
                                              Visibility="{Binding IsChecked, ElementName=ExpandPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="{Binding ControlID}"
                                                        Style="{StaticResource MaterialDesignFlatSecondaryDarkButton}"></Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!--row: 0, col: 1 & 2 -> row that hold toolbox-->
        <!--row: 1, col: 1 -> column that hold page structure in tree view-->
        <!--row: 1, col: 2 -> column that holds the form for selected item from treeview-->
    </Grid>
</UserControl>
